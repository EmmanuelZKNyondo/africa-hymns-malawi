      "content": {
        "verses": [
          {
            "number": 1,
            "lines": [
              "Mtuwa, Mtuwa, Mtuwa! Chiura wa nkhongono zonse!",
              "Mlenji nzamuyimba sumu...;",
              "Mtuwa, Mtuwa, Mtuwa! Wachifundo chosatha!",
              "Mlungu mu utatu, Odalitsika!"
            ]
          },
          {
            "number": 2,
            "lines": [
              "Oyera, Oyera, Oyera! Mulungu wa mphamvu zonse!"
            ]
          }
        ],
        "chorus": null
      }
