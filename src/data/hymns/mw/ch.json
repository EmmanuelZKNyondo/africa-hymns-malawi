    {
      "number": 4,
      "previous_version_number": 2,
      "title": "Lemekeza Mulungu Tate",
      "writer": "",
      "rating": 0,
      "tags": ["nyimbo"],
      "content": {
        "verses": [
          {
            "number": 1,
            "lines": [
              "INU Mulungi, tikuyamikani;",
              "Tivomereza ndinu Ambuyathu;",
              "Ponse, Atate, akugwadirani;",
              "Ndinu wamuyaya!"
            ]
          },
          {
            "number": 2,
            "lines": [
              "Inu akukuzani amithenga;",
              "nanu zam'mwamba ndi zamphamvu zake;",
              "Nanu angelo amitundu yonse;",
              "Akuimbirani."
            ]
          },
          {
            "number": 3,
            "lines": [
              "\"Mbuye Woyera! E, Woyera nokha!",
              "Mbuye Woyera! Mbuye wa makamu!",
              "Ponse ulemu wanu ndi wodzadza;",
              "Pansi ndi Kumwamba\""
            ]
          },
          {
            "number": 4,
            "lines": [
              "Inu atumwi akumveka aja,",
              "Ndi aneneri iyanjana omwe;",
              "Ndi aunyinji anakuferani;",
              "Akuyamikani"
            ]
          },
          {
            "number": 5,
            "lines": [
              "Mpingo Woyera! wa kwa anthu onse;",
              "Ukumverani, Mfumu ndi Atate;",
              "Mwana woona waulemu wonse,",
              "Mzimu, Nkhoswe yemwe."
            ]
          },
          {
            "number": 6,
            "lines": [
              "Khristu Mfumu ya ulemelero!",
              "Mwana wosatha wa Atate Ndinu!",
              "Simunanyoze mimba ya namwali;",
              "Potipulumutsa."
            ]
          },
          {
            "number": 7,
            "lines": [
              "Imfa mutagonjetsa ndi zowawa;",
              "Njira munatsekula tikalowe;",
              "Momwe mukhala Inu ndi Atate;",
              "Mu ulemelero."
            ]
          },
          {
            "number": 8,
            "lines": [
              "Kumva milandu yathu mudzabwera;",
              "Mutithandize atumiki anu;",
              "Mwatiwombola nao mwazi wanu;",
              "Mutipulumutse."
            ]
          },
          {
            "number": 9,
            "lines": [
              "M'tiwerengere M'mwamba ndi oyera;",
              "Mutidalitse ndi'fe anthu anu;",
              "Moyo wosatha mutipatse tonse;",
              "Mutilamulire."
            ]
          },
          {
            "number": 10,
            "lines": [
              "Tsiku ndi tsiku timalemekeza;",
              "Inu tikukuzani osaleka;",
              "Mbuye, m'tisunge tisachimwe lero;",
              "M'tichitire nsinsi."
            ]
          },
          {
            "number": 11,
            "lines": [
              "Mbuye chifundo chanu chitigwere;",
              "Monga tikhulupi'ra Inu nokha;",
              "Tikhulupi'ra zedi mwa 'Nu, Mbuye;",
              "Tisagome konse!"
            ]
          }
        ],
        "chorus": null
      }
    },
    {
      "number": 5,
      "previous_version_number": 3,
      "title": "ATATE wa Kumwambako",
      "writer": "",
      "rating": 0,
      "tags": ["nyimbo"],
      "content": {
        "verses": [
          {
            "number": 1,
            "lines": [
              "ATATE wa Kumwambako,",
              "Munawombola ife, ndi ", 
              "Chikondi chanu chijacho",
              "Tiyamikira Inutu."
            ]
          },
          {
            "number": 2,
            "lines": [
              "Ambuye Yesu Inutu",
              "Munabadwira anthu'fe",
              "Munatifera tonse'fe",
              "Tiyamikira Inutu"
            ]
          },
          {
            "number": 3,
            "lines": [
              "Mzimu Woyera m'mtimamo,",
              "Tiyeretsedwe ndi Inutu",
              "Munatisunga bwinoli,",
              "Tiyamikira Inutu."
            ]
          },
          {
            "number": 4,
            "lines": [
              "Atate, Mwana, Mzimunso,",
              "Ndinu atatu, Mmodzitu",
              "Ochimwa tikupemphani",
              "Mutikululukire'fe."
            ]
          }
        ],
        "chorus": null
      }
    },
    {
      "number": 6,
      "previous_version_number": 4,
      "title": "Lemekeza Mlungu `Tate",
      "writer": "",
      "rating": 0,
      "tags": ["nyimbo"],
      "content": {
        "verses": [
          {
            "number": 1,
            "lines": [
              "LEMEKEZA Mlungu `Tate,",
              "Lemekeza Mlungu Mwana;",
              "Lemekeza Mlungu Mzimu,",
              "Mlungu Mmodzi ndi Wamkulu,",
              "Lemekeza, lemekeza,",
              "Mlungu wathu yemweyo."
            ]
          },
          {
            "number": 2,
            "lines": [
              "M'lemekeze, anakonda,",
              "Natitsuka m'mtima mwathu;",
              "Anatiwombola ife",
              "Tikakhale ndi chifumu.",
              "Lemekeza, lemekeza,",
              "Yesu Mbuye Nsembeyo."
            ]
          },
          {
            "number": 3,
            "lines": [
              "Lemekeza Mfumu yathu,",
              "Mfumu ya mipingo yonse;",
              "Ipambana anthu onse",
              "Akumwamba ndi apansi",
              "Lemekeza, lemekeza,",
              "Mfumu ya mafumuyo."
            ]
          }
        ],
        "chorus": null
      }
    },
