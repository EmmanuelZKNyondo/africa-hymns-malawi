    {
      "number": 11,
      "previous_version_number": 9,
      "title": "E, Chifundo chake",
      "writer": "",
      "rating": 0,
      "tags": ["nyimbo"],
      "content": {
        "verses": [
          {
            "number": 1,
            "lines": [
              "NDI mitima yokondwera,",
              "Mbuye wathu tiyamika."
            ]
          },
          {
            "number": 2,
            "lines": [
              "Dzina lake tibukitsa,",
              "Mlungu ndiye yekhayekha."
            ]
          },
          {
            "number": 3,
            "lines": [
              "Mphamvu yake inalenga,",
              "Dziko lonse ndi Kumwamba."
            ]
          },
          {
            "number": 4,
            "lines": [
              "Anatsogolera kale,",
              "M'chipululu anthu ake."
            ]
          },
          {
            "number": 5,
            "lines": [
              "Ndi chifundo atipenya,",
              "Ife anthu osauka."
            ]
          },
          {
            "number": 6,
            "lines": [
              "Amaweta nyama zonse,",
              "Zingasowe kanthu konse."
            ]
          },
          {
            "number": 7,
            "lines": [
              "Tiimbire Mlungu wathu",
              "Waulemu ndi Wamkulu."
            ]
          },
          {
            "number": 8,
            "lines": [
              "Tithawire kwa Mulungu",
              "Ndiko tikapeze moyo."
            ]
          }
        ],
        "chorus": {
          "lines": [
            "E, chifundo chake chonse,",
            "Ndichosatha nthawi zonse."
          ]
        }
      }
    },
    {
      "number": 12,
      "previous_version_number": null,
      "title": "Nditamatu Ambuyanga",
      "writer": "",
      "rating": 0,
      "tags": ["nyimbo", "Masalimo 146:2"],
      "content": {
        "verses": [
          {
            "number": 1,
            "lines": [
              "NDITAMATU Ambuyangayu,",
              "Moyo wanga wonse ndidzam'tamatu;",
              "Ndiponso m'dziko la Kumwambako.",
              "Masiku anga onse ndidzam'lemekeza Iye,",
              "Sindidzaleka konsekonse mmene ndiri moyotu;",
              "Pa dziko pano pena M'mwambamo."
            ]
          },
          {
            "number": 2,
            "lines": [
              "Ndiye wokondwa, E,", "munthuyo,",
              "Wokhulupilira Mlungu yekhadi;",
              "Wolenga dziko, nyanja, zonsezi.",
              "Choona chake chonse chingokhalatu chosatha,",
              "Apulumutsa onse namadyetsa anthu akewo;",
              "Wokonda ndiye Mlungu wathuyo."
            ]
          },
          {
            "number": 3,
            "lines": [
              "Mlungu kuona athiratu,",
              "Inde m'maso awo osapenyawo;",
              "Natuma akumvera mpumulo.",
              "Amathandiza inde a ulendo ofokatu,",
              "Akazi amasiye, maka ndi ana'wo onsewo;",
              "Olira otonthoza mtimadi."
            ]
          },
          {
            "number": 4,
            "lines": [
              "Nditamatu Ambuyangayu,",
              "Moyo wanga wonse ndidzam'tamatu;",
              "Ndiponso m'dziko la Kumwambako.",
              "Masiku anga onse ndidzam'lemekeza Iye,",
              "Sindidzaleka konsekonse mmene ndiri moyotu;",
              "Pa dziko pano pena M'mwambamo."
            ]
          }
        ],
        "chorus": null
      }
    },
    {
      "number": 13,
      "previous_version_number": 11,
      "title": "Mulungu alinane",
      "writer": "",
      "rating": 0,
      "tags": ["nyimbo", "Masalimo 139"],
      "content": {
        "verses": [
          {
            "number": 1,
            "lines": [
              "PAPHIRI ndi padambo, Ponsepo pali Mlungu;",
              "Pyenda ife m'njira, Mpoima pali Mlungu.",
              "Kokwra maganizo, Komweko kuli Mlungu;",
              "Kumwamba ndi pansipo, Ponsepo pali Mlungu."
            ]
          },
          {
            "number": 2, 
            "lines": [
              "Ndi maso Ambuyathu, Apenyetsetsa ife;",
              "Amadalitsa onse, Okhulupi'ra Iye.",
              "Amamva timbalame, Naveka dziko lonse;",
              "Sataya tizirombo, Asunga zina zonse."
            ]
          },
          {
            "number": 3,
            "lines": [
              "Okwawa pansi inu, Oyenda m'madzi inu;",
              "Oyesa dziko n'kwanu, A m'mlengalenga inu.",
              "Nonsenu ntchito zake, Muona tsiku n'tsiku;",
              "Saleka kusamala, Ndi kudalitsa inu."
            ]
          },
          {
            "number": 4,
            "lines": [
              "Nditama mphamvu yake, Ya Mlungu yondizinga;",
              "N'kafoka andilimbitsa, N'kadwala andichiza.",
              "Pakundisiya bwenzi, Mulungu ali paja;",
              "N'kalowa imfa ine, Alipo Mlungu wanga."
            ]
          }
        ],
        "chorus": {
          "lines": [
            "(Mulungu ali nane!)",
            "",
            "(Ali nane, ali nane",
            "ali nane, ali nane, Aa!",
            "Mulungu ali nane!)"
          ]
        }
      }
    }
