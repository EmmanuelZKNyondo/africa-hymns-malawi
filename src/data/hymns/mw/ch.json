    {
      "number": 11,
      "previous_version_number": 9,
      "title": "E, Chifundo chake",
      "writer": "",
      "rating": 0,
      "tags": ["nyimbo"],
      "content": {
        "verses": [
          {
            "number": 1,
            "lines": [
              "NDI mitima yokondwera,",
              "Mbuye wathu tiyamika."
            ]
          },
          {
            "number": 2,
            "lines": [
              "Dzina lake tibukitsa,",
              "Mlungu ndiye yekhayekha."
            ]
          },
          {
            "number": 3,
            "lines": [
              "Mphamvu yake inalenga,",
              "Dziko lonse ndi Kumwamba."
            ]
          },
          {
            "number": 4,
            "lines": [
              "Anatsogolera kale,",
              "M'chipululu anthu ake."
            ]
          },
          {
            "number": 5,
            "lines": [
              "Ndi chifundo atipenya,",
              "Ife anthu osauka."
            ]
          },
          {
            "number": 6,
            "lines": [
              "Amaweta nyama zonse,",
              "Zingasowe kanthu konse."
            ]
          },
          {
            "number": 7,
            "lines": [
              "Tiimbire Mlungu wathu",
              "Waulemu ndi Wamkulu."
            ]
          },
          {
            "number": 8,
            "lines": [
              "Tithawire kwa Mulungu",
              "Ndiko tikapeze moyo."
            ]
          }
        ],
        "chorus": {
          "lines": [
            "E, chifundo chake chonse,",
            "Ndichosatha nthawi zonse."
          ]
        }
      }
    },
    {
      "number": 12,
      "previous_version_number": null,
      "title": "Nditamatu Ambuyanga",
      "writer": "",
      "rating": 0,
      "tags": ["nyimbo", "Masalimo 146:2"],
      "content": {
        "verses": [
          {
            "number": 1,
            "lines": [
              "NDITAMATU Ambuyangayu,",
              "Moyo wanga wonse ndidzam'tamatu;",
              "Ndiponso m'dziko la Kumwambako.",
              "Masiku anga onse ndidzam'lemekeza Iye,",
              "Sindidzaleka konsekonse mmene ndiri moyotu;",
              "Pa dziko pano pena M'mwambamo."
            ]
          },
          {
            "number": 2,
            "lines": [
              "Ndiye wokondwa, E,", "munthuyo,",
              "Wokhulupilira Mlungu yekhadi;",
              "Wolenga dziko, nyanja, zonsezi.",
              "Choona chake chonse chingokhalatu chosatha,",
              "Apulumutsa onse namadyetsa anthu akewo;",
              "Wokonda ndiye Mlungu wathuyo."
            ]
          },
          {
            "number": 3,
            "lines": [
              "Mlungu kuona athiratu,",
              "Inde m'maso awo osapenyawo;",
              "Natuma akumvera mpumulo.",
              "Amathandiza inde a ulendo ofokatu,",
              "Akazi amasiye, maka ndi ana'wo onsewo;",
              "Olira otonthoza mtimadi."
            ]
          },
          {
            "number": 4,
            "lines": [
              "Nditamatu Ambuyangayu,",
              "Moyo wanga wonse ndidzam'tamatu;",
              "Ndiponso m'dziko la Kumwambako.",
              "Masiku anga onse ndidzam'lemekeza Iye,",
              "Sindidzaleka konsekonse mmene ndiri moyotu;",
              "Pa dziko pano pena M'mwambamo."
            ]
          }
        ],
        "chorus": null
      }
    },
    {
      "number": 13,
      "previous_version_number": 11,
      "title": "Mulungu alinane",
      "writer": "",
      "rating": 0,
      "tags": ["nyimbo", "Masalimo 139"],
      "content": {
        "verses": [
          {
            "number": 1,
            "lines": [
              "PAPHIRI ndi padambo, Ponsepo pali Mlungu;",
              "Pyenda ife m'njira, Mpoima pali Mlungu.",
              "Kokwra maganizo, Komweko kuli Mlungu;",
              "Kumwamba ndi pansipo, Ponsepo pali Mlungu."
            ]
          },
          {
            "number": 2, 
            "lines": [
              "Ndi maso Ambuyathu, Apenyetsetsa ife;",
              "Amadalitsa onse, Okhulupi'ra Iye.",
              "Amamva timbalame, Naveka dziko lonse;",
              "Sataya tizirombo, Asunga zina zonse."
            ]
          },
          {
            "number": 3,
            "lines": [
              "Okwawa pansi inu, Oyenda m'madzi inu;",
              "Oyesa dziko n'kwanu, A m'mlengalenga inu.",
              "Nonsenu ntchito zake, Muona tsiku n'tsiku;",
              "Saleka kusamala, Ndi kudalitsa inu."
            ]
          },
          {
            "number": 4,
            "lines": [
              "Nditama mphamvu yake, Ya Mlungu yondizinga;",
              "N'kafoka andilimbitsa, N'kadwala andichiza.",
              "Pakundisiya bwenzi, Mulungu ali paja;",
              "N'kalowa imfa ine, Alipo Mlungu wanga."
            ]
          }
        ],
        "chorus": {
          "lines": [
            "(Mulungu ali nane!)",
            "",
            "(Ali nane, ali nane",
            "ali nane, ali nane, Aa!",
            "Mulungu ali nane!)"
          ]
        }
      }
    },
    {
      "number": 14,
      "previous_version_number": 12,
      "title": "Ife tonse tiyamike Mlunguyo",
      "writer": "",
      "rating": 0,
      "tags": ["nyimbo"],
      "content": {
        "verses": [
          {
            "number": 1,
            "lines": [
              "MTIMA wanga uyamike,",
              "Mfumu ya Kumwambako,",
              "Anandiwombola ine;",
              "Nanditsuka m'mtimamo."
            ]
          },
          {
            "number": 2,
            "lines": [
              "Tiyamike Mlungu wathu,",
              "Kaamba ka chifundocho;",
              "Nthawi zonse sasinthika,",
              "Mlungi wathu yemweyo."
            ]
          },
          {
            "number": 3,
            "lines": [
              "Nthawi zonse monga 'Tate",
              "Atisamaliratu;",
              "Atisunga m'manja mwake",
              "Atipulumutsatu."
            ]
          },
          {
            "number": 4,
            "lines": [
              "Anthu a mitundu yonse,",
              "Ndiponso a Kumwamba;",
              "Yamikani Mlungu wathu",
              "Ndiye wakukomatu."
            ]
          },
          {
            "number": "last_chorus",
            "lines": [
              "Anthu onse, anthu onse,",
              "Yamikani Mlunguyo."
            ]
          }
        ],
        "chorus": {
          "lines": [
            "Ife tonse, ife tonse",
            "Tiyamike Mlunguyo,"
          ]
        }
      }
    },
    {
      "number": 15,
      "previous_version_number": 13,
      "title": "Yehova ndiye M'busa wanga",
      "writer": "",
      "rating": 0,
      "tags": ["nyimbo", "Masalimo 23"],
      "content": {
        "verses": [
          {
            "number": 1,
            "lines": [
              "YEHOVA ndiye M'busa wanga,",
              "Sin'ngasowe konse;",
              "Andigonetsa pali busa",
              "La misipu yonse."
            ]
          },
          {
            "number": 2,
            "lines": [
              "Kumadzi kuli njiratu,",
              "Andiyendetsa bwino;",
              "Nalimbikitsa moyo wanga,",
              "Ndi chifundo chake."
            ]
          },
          {
            "number": 3,
            "lines": [
              "Pabande lolunjika,",
              "Andilondolera njira;",
              "Chifukwacho cha dzina lake,",
              "Anandisungira."
            ]
          },
          {
            "number": 4,
            "lines": [
              "Chigwa choopsacho cha imfa,",
              "Ndikachilowera;",
              "Ndilibe mantha, muli ndi'ne",
              "Ndodo ndiigwira."
            ]
          },
          {
            "number": 5,
            "lines": [
              "Pamaso pa adaniwo,",
              "Mwayala gome langa;",
              "E, mutu mwaudzoza,",
              "Chisefuka chikho changa."
            ]
          },
          {
            "number": 6,
            "lines": [
              "Zabwino ndi zokoma,",
              "Zinditsata chitsatire;",
              "E, m'nyumba ya Yehova,",
              "Ndidzakhala chikalire."
            ]
          }
        ],
        "chorus": {
          "lines": [
            "(Ndiye M'busa wanga,",
            "Ndiye M'busa wanga!,",
            "Yehova ndiye M'busa wanga.",
            "Sin'ngasowe konse)"
          ]
        }
      }
    },
    {
      "number": 16,
      "previous_version_number": 14,
      "title": "Mtima wanga lemekeza",
      "writer": "",
      "rating": 0,
      "tags": ["nyimbo"],
      "content": {
        "verses": [
          {
            "number": 1,
            "lines": [
              "MTIMA wanga  lemekeza,",
              "Mlungu wako ndi chimwemwe;",
              "Nthawi zonse ndimtamanda,",
              "Ndimuyimbira nyimbo zanga.",
              "Moyo, mphamvu, nzeru zonse,",
              "Zidzamlemekeza konse."
            ]
          },
          {
            "number": 2,
            "lines": [
              "Ndi wamwayi munthu uja,",
              "Am'thandiza Mbuye wake;",
              "Akachita mantha iye,",
              "Am'chotsera nkhawa yake.",
              "Ndipo likam'gwera tsoka,",
              "Amakhulupi'ra kokha."
            ]
          },
          {
            "number": 3,
            "lines": [
              "Mbuye ndiye wachifundo,",
              "Achiritsa akudwala;",
              "Anyamula akufoka,",
              "Nawadyetsatu a njala.",
              "Wakusunga mlendo ndiye,",
              "Nathandiza amasiye."
            ]
          },
          {
            "number": 4,
            "lines": [
              "Ndiye Mbuye wa ambuye,",
              "Mphamvu yake ndi yokwana;",
              "Adzakhala chikhalire.",
              "Mfumu yathu yopambana.",
              "Aleluya! Kondwerani!",
              "Mlungu wathu yamikani."
            ]
          }
        ],
        "chorus": null
      }
    },
    {
      "number": 17,
      "previous_version_number": 15,
      "title": "Mulungu ndiye M'busa wanga",
      "writer": "",
      "rating": 0,
      "tags": ["nyimbo", "Masalimo 23"],
      "content": {
        "verses": [
          {
            "number": 1,
            "lines": [
              "MULUNGU ndiye M'busa wanga,",
              "Sindisowa konse;",
              "Amandiweta nandidyetsa,",
              "Nandipatsa zonse."
            ]
          },
          {
            "number": 2,
            "lines": [
              "M'mitsinje yamtendere mtima,",
              "Wanga aumwetsa;",
              "Mapazi omwe m'njira,",
              "Yolungama nayendetsa."
            ]
          },
          {
            "number": 3,
            "lines": [
              "Za mdima, infa, nkhondo ndi",
              "Zoipa sindiopa;",
              "Ndikakhumudwa ndi kutopa,",
              "Andipulumutsa."
            ]
          },
          {
            "number": 4,
            "lines": [
              "Podwala ine, povutidwa,",
              "Andisamalira;",
              "Pondisautsa 'dani anga,",
              "Nandithangatira."
            ]
          },
          {
            "number": 5,
            "lines": [
              "Chisomo ndi zokoma zake,",
              "Sizileka konse;",
              "Ndi m'nyumba ya Mulungu,",
              "Ndidzakhala nsiku zonse."
            ]
          }
        ],
        "chorus": {
          "lines": [
            "(Ndiye M'busa wanga,",
            "Ndiye M'busa wanga!,",
            "Mulungu ndiye M'busa wanga.",
            "Sindisowa konse.)"
          ]
        }
      }
    },
    {
      "number": 18,
      "title": "Pokhala inu mpotikonda ndithu",
      "previous_version_number": 84,
      "writer": "",
      "rating": 0,
      "tags": ["nyimbo", "Masalimo 84"],
      "content": {
        "verses": [
          {
            "number": 1,
            "lines": [
              "POKHALA inu mpotikonda ndithu,",
              "Yehova Wamakamu.",
              "Moyo wanga; ulakalaka Inu,",
              "Ukomokanso ndikufuna,",
              "Mabwalo a Yehova.",
              "Mtima wanga ndi thupi langa,",
              "Zifuulira kwa Mulungu wa moyo."
            ]
          },
          {
            "number": 2,
            "lines": [
              "Odala iwotu akugonera,",
              "M'nyumba mwanu Yehova;",
              "Nthawi zonse akulemekezani,",
              "Odala munthu yemwe,",
              "Mphamvu yake iri mwa Inu;",
              "Mu mtima mwake ndi moyera",
              "Mulitu makwalala a ku Zioni."
            ]
          }
        ],
        "chorus": null
      }
    },
    {
      "number": 19,
      "title": "MULUNGU akhale nao",
      "previous_version_number": 310,
      "writer": "",
      "rating": 0,
      "tags": ["nyimbo"],
      "crossReference": [],
      "content": {
        "verses": [
          {
            "number": 1,
            "lines": [
              "MULUNGU akhale nao,",
              "Ulemelero ndi dalitso,",
              "Ndiye Atate, Mwana,",
              "Mzimu Woyera, Mlungu Mmodzi."
            ]
          },
          {
            "number": 2,
            "lines": [
              "tsopano, poyamba paja,",
              "Masiku onse alinkudza;",
              "Mphamvu, ulemelero,",
              "Dalitso, chipambano."
            ]
          }
        ]
      }
