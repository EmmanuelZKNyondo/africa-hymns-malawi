{
  "id": "lords-prayer",
  "title": "Pemphero la Ambuye",
  "content": [
    "Atate athu ali kumwamba,",
    "dzina lanu liyeretsedwe.",
    "Ufumu wanu ubwere,",
    "chifuniro chanu chichitike,",
    "pa dziko lapansi monga momwe zilili kumwamba.",
    "",
    "Tipatseni lero chakudya chathu cha tsiku ndi tsiku.",
    "Ndipo mutikhululukire machimo athu,",
    "monga ifenso timakhululukira omwe amatichimwira.",
    "Ndipo musatilole kulowa mu mayeso,",
    "koma titipulumutseni ku zoipa.",
    "",
    "Pakuti ufumu ndi wanu,",
    "ndi mphamvu, ndi ulemerero,",
    "mpaka muyaya. Amen."
  ]
}