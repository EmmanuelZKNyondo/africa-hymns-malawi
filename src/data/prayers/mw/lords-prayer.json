{
  "id": "lords-prayer",
  "title": {
    "en": "The Lord's Prayer",
    "ch": "Pemphero la Ambuye",
    "ny": "Pemphero la Ambuye"
  },
  "content": {
    "en": [
      "Our Father, who art in heaven,",
      "hallowed be thy name.",
      "Thy kingdom come,",
      "thy will be done,",
      "on earth as it is in heaven."
    ],
    "ch": [
      "Atate athu ali kumwamba,",
      "dzina lanu liyeretsedwe.",
      "Ufumu wanu ubwere,",
      "chifuniro chanu chichitike,",
      "pa dziko lapansi monga momwe zilili kumwamba."
    ],
    "ny": [
      "Atate athu ali kumwamba,",
      "dzina lanu liyeretsedwe.",
      "Ufumu wanu ubwere,",
      "chifuniro chanu chichitike,",
      "pa dziko lapansi monga momwe zilili kumwamba."
    ]
  }
}