{
  "id": "apostles-creed",
  "title": "Chikhulupiriro cha Atumwi",
  "content": [
    "Ndikukhulupirira Mulungu, Atate wamphamvu zonse,",
    "wolenga kumwamba ndi dziko lapansi.",
    "",
    "Ndikukhulupirira Yesu Khristu, Mwana wake yekhayo, Ambuye athu,",
    "amene anakonzedwa ndi Mzimu Woyera,",
    "kubadwa wa Namwali Mariya,",
    "anavutika pansi pa Pontiyo Pilato,",
    "anapachikidwa, anamwalira, nayikidwa m'manda;",
    "anatsikira kwa akufa.",
    "Pa tsiku lachitatu anauka;",
    "anakwera kumwamba,",
    "akhala kudzanja lamanja la Atate,",
    "ndipo adzabweranso kuweruza amoyo ndi akufa.",
    "",
    "Ndikukhulupirira Mzimu Woyera,",
    "Tchalitchi choyera cha katolika,",
    "chigwirizano cha oyera,",
    "chikhululukiro cha machimo,",
    "chiuko cha thupi,",
    "ndi moyo wosatha", 
    "Amen."
  ]
}